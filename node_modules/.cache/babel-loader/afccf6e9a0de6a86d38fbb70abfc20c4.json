FA;AAKA,EAAA,IAAA,EAAA;AAAA,WAAA;AACA,MAAA,YAAA,EAAA;AACA,QAAA,IAAA,EAAA,UADA;AAEA,QAAA,MAAA,EAAA,gBAFA;AAGA,QAAA,YAAA,EACA,8EAJA;AAKA,QAAA,gBAAA,EAAA,IALA;AAMA,QAAA,SAAA,EAAA,CACA;AACA,UAAA,EAAA,EAAA,CADA;AAEA,UAAA,KAAA,EACA,yEAHA;AAIA,UAAA,iBAAA,EAAA,IAJA;AAKA,UAAA,QAAA,EAAA,CACA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,UAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WADA,EAEA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,WAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WAFA,EAGA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,WAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WAHA,EAIA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,cAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WAJA,CALA;AAWA,UAAA,gBAAA,EAAA,sCAXA;AAYA,UAAA,kBAAA,EAAA;AAZA,SADA,EAeA;AACA,UAAA,EAAA,EAAA,CADA;AAEA,UAAA,KAAA,EAAA,4BAFA;AAGA,UAAA,iBAAA,EAAA,IAHA;AAIA,UAAA,QAAA,EAAA,CACA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,iCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WADA,EAMA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EACA,2DAHA;AAIA,YAAA,UAAA,EAAA;AAJA,WANA,EAYA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,sCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAZA,EAiBA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,yCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAjBA,CAJA;AA2BA,UAAA,gBAAA,EAAA,sCA3BA;AA4BA,UAAA,kBAAA,EAAA;AA5BA,SAfA,EA6CA;AACA,UAAA,EAAA,EAAA,CADA;AAEA,UAAA,KAAA,EAAA,yDAFA;AAGA,UAAA,iBAAA,EAAA,IAHA;AAIA,UAAA,QAAA,EAAA,CACA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,oBAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WADA,EAEA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,oBAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WAFA,EAGA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,kBAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WAHA,EAIA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,kBAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WAJA,CAJA;AAUA,UAAA,gBAAA,EAAA,sCAVA;AAWA,UAAA,kBAAA,EAAA;AAXA,SA7CA,EA0DA;AACA,UAAA,EAAA,EAAA,CADA;AAEA,UAAA,KAAA,EACA,6EAHA;AAIA,UAAA,iBAAA,EAAA,IAJA;AAKA,UAAA,QAAA,EAAA,CACA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,sCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WADA,EAMA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,uCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WANA,EAWA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,6CAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAXA,EAgBA;AAAA,YAAA,EAAA,EAAA,GAAA;AAAA,YAAA,KAAA,EAAA,oBAAA;AAAA,YAAA,UAAA,EAAA;AAAA,WAhBA,CALA;AAuBA,UAAA,gBAAA,EAAA,sCAvBA;AAwBA,UAAA,kBAAA,EAAA;AAxBA,SA1DA,EAoFA;AACA,UAAA,EAAA,EAAA,CADA;AAEA,UAAA,KAAA,EAAA,6DAFA;AAGA,UAAA,iBAAA,EAAA,IAHA;AAIA,UAAA,QAAA,EAAA,CACA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,wCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WADA,EAMA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EACA,4DAHA;AAIA,YAAA,UAAA,EAAA;AAJA,WANA,EAYA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,wCAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAZA,EAiBA;AACA,YAAA,EAAA,EAAA,GADA;AAEA,YAAA,KAAA,EAAA,+BAFA;AAGA,YAAA,UAAA,EAAA;AAHA,WAjBA,CAJA;AA2BA,UAAA,gBAAA,EAAA,sCA3BA;AA4BA,UAAA,kBAAA,EAAA;AA5BA,SApFA,CANA;AAyHA,QAAA,sBAAA,EAAA,uCAzHA;AA0HA,QAAA,uBAAA,EACA;AA3HA;AADA,KAAA;AAAA,GALA;AAoIA,EAAA,OApIA,qBAoIA;AAAA;;AACA,SAAA,SAAA,CAAA,YAAA;AACA,MAAA,KAAA,CAAA,WAAA;AACA,KAFA;AAGA;AAxIA,CAAA","sourcesContent":["<template lang=\"pug\">\n.curso-main-container.pb-3\n  BannerInterno(:subTitulo=\"'NOMBRE TEMA 3'\")\n  .container.tarjeta.tarjeta--blanca.p-4.p-md-5\n    \n    .row.mb-4\n      .d-none.d-xl-block.col-5(data-aos=\"fade-right\")\n        img.h-100(src='@/assets/curso/unidad/img-40.png', alt='Texto que describa la imagen')\n      .col-12.col-xl-7.d-flex.flex-column\n        .bg-verde.p-4.mb-4(data-aos=\"fade-up\")\n          span En el transcurso de la unidad hemos explorado cómo la afectividad y el vínculo en la infancia son fundamentales para el desarrollo emocional, social y cognitivo de los niños. En este último tema, abordaremos las relaciones interpersonales en la infancia y su influencia en el desarrollo integral.\n        span Para reflexionar sobre ello, le invitamos a leer la corta fábula del erizo, atribuida al filósofo Arthur Schopenhauer, que busca representar los dilemas y desafíos inherentes a las relaciones humanas, especialmente aquellos relacionados con la cercanía emocional y las diferencias individuales. Esperamos que la disfrute.\n    \n\n    .bg-amarillo.bg-full-width\n      .px-5.pb-md-3\n\n        .row\n          .col-12.col-xl-6.py-4\n            p.mb-4.text-bold La fábula del erizo\n            p.mb-4(data-aos=\"fade-up\") Durante un frío invierno, un grupo de erizos buscaba refugio para protegerse del intenso frío. Mientras intentaban mantenerse cálidos, se acercaban unos a otros para compartir calor. Sin embargo, al hacerlo, las púas de cada uno empezaban a herir a los demás, causando dolor y obligándolos a separarse.\n            span(data-aos=\"fade-up\") Al alejarse, se sentían nuevamente expuestos al frío, lo que les obligaba a intentar acercarse otra vez. Este ciclo de acercarse y alejarse continuó hasta que, poco a poco, los erizos encontraron una distancia justa: lo suficientemente cerca como para compartir calor, pero no tanto como para lastimarse mutuamente con sus púas.\n          .col-6.d-none.d-xl-block\n            img.h-100(src='@/assets/curso/unidad/img-41.png', alt='Texto que describa la imagen')\n\n    .row.mb-4\n      .d-none.d-xl-block.col-5(data-aos=\"fade-right\")\n        img.h-100(src='@/assets/curso/unidad/img-42.png', alt='Texto que describa la imagen')\n      .col-12.col-xl-7\n        p.mb-4(data-aos=\"fade-up\") <b>Moraleja:</b> aunque todos necesitamos cercanía y afecto, también es importante respetar los límites individuales para evitar causar daño a los demás o a nosotros mismos. La convivencia saludable requiere equilibrio entre la intimidad y el espacio personal.\n        span Quisiera aprovechar esta fábula para que analicemos algunos aspectos relevantes de la importancia de las relaciones interpersonales en la infancia:\n\n    .row.mb-4.mx-0\n      .col-12.col-xl-8.d-flex.align-items-center.bg-verde.p-4(data-aos=\"fade-right\")\n        p.mb-0(data-aos=\"fade-up\") Como lo hemos venido viendo a lo largo de la unidad, la infancia es una etapa crítica en la que los niños desarrollan habilidades sociales y emocionales que les permiten interactuar con otros. Estas relaciones se dan en distintos contextos, como el familiar, escolar y social y, según (Papalia et al., 2017), son esenciales para la construcción de habilidades como la empatía, la comunicación y la resolución de conflictos. Además, influyen en la formación de la identidad y en la capacidad de los niños para establecer vínculos saludables a lo largo de su vida .\n      .d-none.d-xl-block.col-4.px-0(data-aos=\"fade-left\")\n        img.h-100(src='@/assets/curso/unidad/img-43.png', alt='Texto que describa la imagen')\n\n    p.mb-4(data-aos=\"fade-up\") En este mismo sentido, la moraleja de la fábula del erizo tiene una relación profunda con las relaciones interpersonales en la infancia, ya que refleja los desafíos y aprendizajes que los niños experimentan al construir vínculos con sus cuidadores y pares (Berger, 2007). En esta etapa, los niños están desarrollando habilidades sociales y emocionales fundamentales, y las dinámicas de acercamiento y distanciamiento descritas en la fábula son especialmente relevantes.\n    p.mb-4(data-aos=\"fade-up\") Estudiemos algunos de esos factores:\n\n    .row.mb-4\n      .col-12.col-lg-5.d-none.d-lg-block(data-aos=\"fade-right\")\n        img(src='@/assets/curso/unidad/img-44.png', alt='Texto que describa la imagen')\n      .col-12.col-lg-7(data-aos=\"fade-left\")\n        AcordionA(tipo=\"b\")\n          .div(titulo=\"Necesidad de cercanía emocional\")\n            p En la infancia, los niños dependen de sus cuidadores para sentirse seguros y protegidos. El apego seguro permite al niño explorar su entorno con confianza, sabiendo que cuenta con una base emocional sólida. La moraleja de la fábula resalta la importancia de esa cercanía emocional, dado que los niños necesitan el \"calor\" de las relaciones afectivas, para su desarrollo emocional y social.\n          .div(titulo=\"Límites y diferencias individuales\")\n            p Al igual que los erizos, los niños y sus cuidadores (o pares) tienen características individuales que pueden causar \"roces\" y estos pueden surgir; por ejemplo, cuando un niño expresa sus emociones de forma intensa o cuando no sabe cómo manejar los conflictos que se le presentan en la convivencia con los otros. Enseñarles a reconocer y respetar los límites de los demás desde temprana edad, es clave para fomentar relaciones interpersonales saludables, así como lo plantea Vygotsky (1979): “El aprendizaje y el desarrollo surgen a partir de la interacción social, donde el niño aprende a manejar sus emociones y a entender las perspectivas de los demás\". \n          .div(titulo=\"Aprendizaje gradual de la convivencia\")\n            p En la infancia, los niños están en un proceso constante de aprendizaje sobre cómo relacionarse con los demás. Esto incluye aprender a compartir, resolver conflictos, negociar y cooperar. Tal como los erizos en la fábula, los niños necesitan tiempo y guía para encontrar ese \"punto medio\" en el que puedan relacionarse sin lastimar a los demás ni sentirse heridos. Goleman (1995), lo respalda cuando habla de que es necesario para los niños y las personas aprender a reconocer las emociones propias y saber cómo responder a las emociones del otro, solo así se pueden construir relaciones positivas.\n          .div(titulo=\"Respeto mutuo y empatía\")\n            p En esta fábula, se destaca la necesidad de respetar las diferencias de los demás mientras se mantiene una conexión afectiva. En la infancia, enseñar a los niños a ser empáticos y a respetar las emociones y necesidades de los demás les ayuda a construir relaciones más equilibradas y significativas, o como lo dicen Shonkoff et al. (2012), \"Las relaciones afectivas tempranas actúan como un amortiguador que protege al niño del estrés tóxico, permitiendo un desarrollo emocional y cognitivo saludable\"; es decir, que las experiencias de cercanía o falta de ella durante la infancia, tienen un impacto directo en el desarrollo cerebral y emocional. Las relaciones equilibradas atenúan el estrés y promueven el bienestar.\n          .div(titulo=\"Influencia del entorno\")\n            p El ambiente en el que los niños crecen, juega un papel crucial en cómo manejan esta dinámica de acercamiento y distancia (Ainsworth, 1978; Vygotsky, 1978). Un entorno cálido, afectuoso y respetuoso, donde los cuidadores les brinden seguridad emocional pero también les permitan explorar su independencia, fomenta el desarrollo de habilidades sociales saludables; en este sentido, Rogers (1961), argumentó que la aceptación incondicional y la empatía, son esenciales para el desarrollo personal. Los niños, como los erizos, necesitan sentirse aceptados y seguros en sus relaciones para poder crecer emocionalmente, pero sin miedo a ser rechazados o heridos.\n\n    #t_3_1.titulo-segundo(data-aos=\"flip-up\")\n      div.d-flex\n        span.me-3 3.1  \n        h2 El juego como el motor principal de las relaciones sociales en la infancia\n\n    p.mb-4(data-aos=\"fade-up\") El juego es un elemento esencial en el desarrollo social y emocional de los niños, ya que les permite explorar roles, expresar emociones y aprender habilidades interpersonales de forma natural.\n\n    .row.bg-azul.bg-full-width.py-4.mb-4\n      div.px-5.pb-md-3.py-4.d-flex\n        .d-none.d-xl-block.col-xl-5.mx-auto.mt-4.mt-xl-0(data-aos=\"fade-right\")\n          img.h-100(src='@/assets/curso/unidad/img-45.png', alt='Texto que describa la imagen')\n        .col-12.col-xl-7.d-flex.ps-4.ps-xl-5.align-items-center.flex-column(data-aos=\"fade-left\")\n          h2.mb-4.pb-2.me-auto El juego\n          p.mb-5 En el PDF El juego, se analiza cómo las actividades lúdicas favorecen la socialización, fomentan la empatía y fortalecen la comunicación entre pares, además de abordar los desafíos y beneficios que el juego aporta al crecimiento integral durante esta etapa.\n          a.d-flex.me-auto.w-fit.bg-white.box-shadow.cursor-pointer(data-aos=\"zoom-in\" :href=\"obtenerLink('/downloads/Anexos_El juego como el motor principal de las relaciones sociales en la infancia.pdf')\" target=\"_blank\")\n            img.h-100(style=\"width: 48px\" src='@/assets/componentes/pdf-icon-square.svg', alt='Texto que describa la imagen')\n            p.text-small.fs-14px.my-auto.px-2 <strong>Anexo.</strong> El juego.\n\n    #t_3_2.titulo-segundo(data-aos=\"flip-up\")\n      div.d-flex\n        span.me-3 3.2  \n        h2 El contexto escolar y las relaciones\n\n    p.mb-4(data-aos=\"fade-up\") Otro espacio clave donde se da el desarrollo de las conexiones en la infancia, es el entorno escolar; en este contexto, los niños no solo interactúan con sus compañeros, sino también con figuras de autoridad como maestros, quienes desempeñan un papel importante en la mediación de conflictos y el fomento de un ambiente inclusivo (Bronfenbrenner, 1987). La escuela es un microcosmos social donde los niños aprenden a adaptarse a normas sociales más amplias, como el respeto por la diversidad y la cooperación en grupo.\n\n    .row.mb-4\n      .col-5.d-none.d-xl-block(data-aos=\"fade-right\")\n        img(src='@/assets/curso/unidad/img-46.png', alt='Texto que describa la imagen')\n      .col-12.col-xl-7(data-aos=\"fade-left\")\n        .bg-azul.p-4.mb-4\n          span Así mismo, los niños que desarrollan relaciones positivas en la escuela, tienden a tener un mejor rendimiento académico y menos problemas emocionales. Por el contrario, aquellos que enfrentan exclusión social o relaciones conflictivas, pueden experimentar dificultades, tanto en el aprendizaje como en su desarrollo emocional.\n        span Claro está que en esta dinámica, también intervienen factores culturales y sociales. Según Páez y Zuleta (2023), las culturas colectivistas, como las de Asia o América Latina, tienden a fomentar relaciones más interdependientes, donde la familia y el grupo social son centrales en la vida del niño. En contraste, las culturas individualistas, como las de algunos países occidentales, suelen enfatizar la autonomía y las relaciones independientes. Estas diferencias culturales moldean la forma en que los niños perciben y gestionan sus relaciones interpersonales.\n\n    .d-flex.mb-4.align-items-start.bg-verde.p-4(data-aos=\"fade-up\")\n      img.me-3(style=\"width: 90px\" src='@/assets/curso/unidad/img-47.svg', alt='Texto que describa la imagen')\n      .d-flex.flex-column\n        p.pe-xl-3.mb-0(data-aos=\"fade-up\") Un aspecto central de las relaciones entre estudiantes en la escuela es la amistad, que surge a partir de la interacción diaria y los intereses compartidos. Fomentar y educar en el valor de la amistad es tan esencial para la convivencia como el respeto, la empatía y la solidaridad. \n\n    .row.mb-4\n      .col-12.col-xl-7\n        p.mb-4(data-aos=\"fade-up\") Las amistades en la infancia, proporcionan una primera aproximación a la vida social desde una perspectiva de igualdad y contribuyen al desarrollo integral de los niños y adolescentes, permitiéndoles experimentar y compartir emociones y experiencias como la alegría, la tristeza y la cooperación.\n        .bg-azul.p-4\n          span Las amistades también son cruciales para el desarrollo de habilidades sociales y comunicativas, necesarias para la vida en comunidad. Se ha observado que las relaciones amistosas basadas en la sinceridad y el afecto, ayudan a reducir los impulsos agresivos y la resolución violenta de conflictos, promoviendo el diálogo y la comunicación asertiva .\n      .d-none.d-xl-block.col-5(data-aos=\"fade-left\")\n        img.h-100(src='@/assets/curso/unidad/img-48.png', alt='Texto que describa la imagen')\n\n\n    .bg-amarillo.bg-full-width.mb-5\n      .px-5.pb-md-3.py-4\n\n        .row\n          .col-6.d-none.d-xl-block\n            img(src='@/assets/curso/unidad/img-49.png', alt='Texto que describa la imagen')\n          .col-12.col-xl-6.d-flex.flex-column.justify-content-center\n            p.mb-0(data-aos=\"fade-up\") En síntesis, la afectividad, los vínculos y las experiencias interpersonales en  la infancia, tienen un impacto duradero. Las relaciones tempranas no solo afectan el bienestar emocional inmediato de los niños, sino que también influyen en su capacidad para formar relaciones saludables en la adultez. Según Erikson (1963), citado por Regader (2015), la etapa de la infancia está relacionada con el desarrollo de la confianza básica, un componente esencial para establecer relaciones satisfactorias en el futuro. Desde los vínculos familiares hasta las interacciones con pares y el entorno escolar, cada relación contribuye al desarrollo emocional, social y cognitivo del niño. Comprender la importancia de estas interacciones y promover entornos positivos, puede ayudar a los niños a construir una base sólida para su vida futura.\n\n    .bg-full-width.border-top-9-azul\n      .px-4.px-md-5.pt-5.pb-0\n        h2 Material complementario\n        .row\n          .col-12.col-md-6.col-lg-8\n            p.d-flex.my-4\n              img.me-3.mb-auto.mt-1(src='@/assets/componentes/book.svg' :style=\"{'max-width':'16px'}\")\n              a.text-small.text-primary(target=\"_blank\" href=\"https://elibro.net/es/ereader/tecnologicadeloriente/167031?page=8\") Fontán García, J. & Fontán de Bedout, L. (2020). La escuela que necesitamos hoy. Ediciones Morata, S. L. [Libro]\n            \n            p.d-flex.my-4\n              img.me-3.mb-auto.mt-1(src='@/assets/componentes/book.svg' :style=\"{'max-width':'16px'}\")\n              a.text-small.text-primary(target=\"_blank\" href=\"https://www.ciberindex.com/index.php/p/article/view/13244i\") Gómez, R. G. (2021). Uso de pantallas en la infancia. Presencia, e13244i-e13244i. [Artículo]\n            \n            p.d-flex.my-4\n              img.me-3.mb-auto.mt-1(src='@/assets/componentes/youtube-icon.svg' :style=\"{'max-width':'16px'}\")\n              a.text-small.text-primary(target=\"_blank\" href=\"https://youtu.be/9b8Dsm4YEFA?si=MXHKW4WNC5mASTzy\") Fundación poma. (2024). #Masterclass -Importancia del juego en la primera infancia. [Vídeo]\n          \n          .col-12.col-md-6.col-lg-3\n            figure\n              img(src='@/assets/componentes/material-complementario.svg' alt='Imagen de material complementario')\n\n    .bg-full-width.border-top.actividad(style=\"background-color: #ebf1f5; border-top: 5px solid #f5c145 !important\")\n      .p-4.p-md-5\n        #Actividad                \n          <Actividad :cuestionario=\"cuestionario\"/>\n\n</template>\n\n<script>\nimport BannerInterno from '../../components/plantilla/BannerInterno'\nexport default {\n  name: 'Tema3',\n  components: {\n    BannerInterno,\n  },\n  data: () => ({\n    cuestionario: {\n      tema: 'Unidad 1',\n      titulo: 'Ponte a prueba',\n      introduccion:\n        'Demuestra lo que aprendiste en esta unidad y pon a prueba tus conocimientos.',\n      barajarPreguntas: true,\n      preguntas: [\n        {\n          id: 1,\n          texto:\n            '¿Qué efecto tiene el juego simbólico en las relaciones interpersonales?',\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Ninguno.', esCorrecta: false },\n            { id: 'b', texto: 'Negativo.', esCorrecta: false },\n            { id: 'c', texto: 'Positivo.', esCorrecta: true },\n            { id: 'd', texto: 'Destructivo.', esCorrecta: false },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 2,\n          texto: '¿Qué es el juego paralelo?',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Cuando los niños juegan juntos.',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto:\n                'Cuando los niños juegan solos, pero cerca de otros niños.',\n              esCorrecta: true,\n            },\n            {\n              id: 'c',\n              texto: 'Cuando los niños juegan con adultos.',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto: 'Cuando los niños no juegan en absoluto.',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 3,\n          texto: '¿Qué tipo de juego es más común en la primera infancia?',\n          barajarRespuestas: true,\n          opciones: [\n            { id: 'a', texto: 'Juego competitivo.', esCorrecta: false },\n            { id: 'b', texto: 'Juego cooperativo.', esCorrecta: false },\n            { id: 'c', texto: 'Juego simbólico.', esCorrecta: true },\n            { id: 'd', texto: 'Juego solitario.', esCorrecta: false },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 4,\n          texto:\n            '¿Cómo pueden los padres apoyar las relaciones interpersonales de sus hijos?',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Fomentando el juego con otros niños.',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Limitando las interacciones sociales.',\n              esCorrecta: false,\n            },\n            {\n              id: 'c',\n              texto: 'Enfocándose solo en actividades académicas.',\n              esCorrecta: false,\n            },\n            { id: 'd', texto: 'Evitando el juego.', esCorrecta: false },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 5,\n          texto: '¿Qué es una relación interpersonal negativa en la infancia?',\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Una relación basada en el apoyo mutuo.',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto:\n                'Una relación con conflictos constantes y falta de respeto.',\n              esCorrecta: true,\n            },\n            {\n              id: 'c',\n              texto: 'Una relación con comunicación abierta.',\n              esCorrecta: false,\n            },\n            {\n              id: 'd',\n              texto: 'Una relación con cooperación.',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n      ],\n      mensaje_final_aprobado: '¡Excelente! Ha superado la actividad.',\n      mensaje_final_reprobado:\n        'Le recomendamos volver a revisar el componente formativo e intentar nuevamente la actividad didáctica.',\n    },\n  }),\n  mounted() {\n    this.$nextTick(() => {\n      this.$aosRefresh()\n    })\n  },\n}\n</script>\n\n<style lang=\"sass\">\n.material-complementario\n  padding-top: 3rem\n  border-top: 9px solid $color-sistema-e\n</style>\n"],"sourceRoot":"src/views/curso"}]}